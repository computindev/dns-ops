# DNS Ops Workbench Environment Configuration
# Copy to .env for local development
# See docs/guides/railway-deploy.md for production setup

# =============================================================================
# REQUIRED — Local Development
# =============================================================================

# PostgreSQL connection string (authoritative data store)
# Both web and collector connect to the same database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dns_ops

# Collector service URL (web app proxies requests to this)
COLLECTOR_URL=http://localhost:3001

# Node environment
NODE_ENV=development

# =============================================================================
# REQUIRED — Production Only
# =============================================================================

# Shared secret for web → collector service auth (≥16 chars)
# Generate: openssl rand -hex 16
# Must match between web and collector
# INTERNAL_SECRET=

# Better Auth session secret — encrypts session cookies (read implicitly by
# better-auth at runtime; prod-required on Railway)
# Generate: openssl rand -hex 16
# BETTER_AUTH_SECRET=

# Public web domain — canonical origin (read implicitly by better-auth;
# prod-required on Railway)
# WEB_DOMAIN=https://app.dns-ops.example.com

# =============================================================================
# COLLECTOR OPTIONS
# =============================================================================

# Collector HTTP port (default: 3001)
# PORT=3001

# Redis URL for BullMQ job queue (optional)
# Without Redis: everything runs synchronously (fine for V1)
# With Redis: enables scheduled monitoring refresh, async fleet reports, job retry
# REDIS_URL=redis://localhost:6379

# Start BullMQ workers (requires REDIS_URL)
# WORKER_ENABLED=true

# Enable active probing — MTA-STS, SMTP STARTTLS (disabled by default)
# READ docs/security/probe-sandbox-review.md BEFORE enabling in production
# ENABLE_ACTIVE_PROBES=false

# Probe timeout and concurrency
# PROBE_TIMEOUT_MS=30000
# PROBE_CONCURRENCY=5

# HTTP endpoint for centralized error reporting (Sentry ingest, etc.)
# Falls back to console logging when unset
# ERROR_REPORTING_ENDPOINT=

# =============================================================================
# WEB APP OPTIONS
# =============================================================================

# Cloudflare Hyperdrive connection (production, set via wrangler)
# Takes precedence over DATABASE_URL when both are set
# HYPERDRIVE_URL=

# Service-to-service API key secret (optional, ≥16 chars)
# Used for X-API-Key header authentication
# API_KEY_SECRET=

# Comma-separated admin email allowlist for privileged web routes
# ADMIN_EMAILS=admin@example.com

# Web app public URL (used for Domain360 links in webhooks)
# WEB_APP_URL=https://app.dns-ops.example.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Delegation tab in Domain 360 (default: enabled)
# VITE_FEATURE_DELEGATION=true

# DNS change simulation panel (default: disabled)
# VITE_FEATURE_SIMULATION=false

# Legacy DMARC/DKIM tool deep-link URLs (optional)
# When unset, legacy bridge returns 503 with clear message
# VITE_DMARC_TOOL_URL=
# VITE_DKIM_TOOL_URL=

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Database TLS certificate verification (production only)
# Set to 'false' to accept self-signed certs (not recommended)
# DB_TLS_REJECT_UNAUTHORIZED=true
